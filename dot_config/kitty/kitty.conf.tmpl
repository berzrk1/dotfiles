include keybinds.conf

# Fonts
font_family      family="Maple Mono NF"
bold_font        auto
italic_font      auto
bold_italic_font auto
{{- if eq .chezmoi.os "darwin" }}
font_size        18
{{- else }}
font_size        15
{{- end }}


# Scrollback
scrollback_lines 2000
scrollback_pager_history_size 4000


# Bell
enable_audio_bell no


# Background
background_opacity 0.8

# tabs
tab_bar_edge top
tab_bar_align center
tab_bar_style powerline
tab_powerline_style slanted

{{if eq .chezmoi.os "darwin" }}
# MacOS Specific
shell /opt/homebrew/bin/fish --login --interactive
{{- end }}

# BEGIN_KITTY_THEME
# Tokyo Night
include current-theme.conf
# END_KITTY_THEME
